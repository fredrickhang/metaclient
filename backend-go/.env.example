# ── 数据库 ────────────────────────────────────────────────
# Supabase PostgreSQL 连接字符串
# Project Settings → Database → Connection string → URI (Session mode, port 5432)
DB_DSN=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?sslmode=require

# ── 服务配置 ──────────────────────────────────────────────
SERVER_PORT=8080
GIN_MODE=debug

# ── RunningHub ────────────────────────────────────────────
# 在 RunningHub 控制台 → API 管理 中获取
RUNNINGHUB_API_KEY=your_runninghub_api_key_here
